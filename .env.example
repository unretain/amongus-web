# Copy this file to ".env" and fill in the values. NEVER commit the real .env.
# (.env is already gitignored.)

# Base58 private key of the wallet that holds the $TRENCHUS prize pool.
# This wallet must hold $TRENCHUS tokens AND some SOL for fees.
# SECRET — never share, never commit.
DEV_WALLET_PRIVATE_KEY=

# The $TRENCHUS token mint / contract address (public).
TOKEN_MINT_ADDRESS=CB9LL9nwAuiUjY6PioScx7qr7FPM6wXGAerQ79hfpump

# Solana RPC endpoint. The public one is rate-limited; use Helius/QuickNode for production.
SOLANA_RPC=https://api.mainnet-beta.solana.com
